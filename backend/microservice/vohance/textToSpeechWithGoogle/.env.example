# Gemini Text-to-Speech Service Configuration
# =============================================
# このファイルを .env にコピーして、実際の値を設定してください

# 必須環境変数
# =============================================

# Gemini API キー（必須）
# Google AI Studio から取得: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Google Cloud プロジェクトID（必須）
# GCP Console から取得
GOOGLE_CLOUD_PROJECT=your-project-id

# オプション環境変数
# =============================================

# サービス設定
SERVICE_NAME=text-to-speech-with-google
SERVICE_VERSION=2.0.0
PORT=8080

# デバッグモード（true/false）
DEBUG=true

# Google Cloud 認証（ローカル開発時）
# サービスアカウントキーのパス（オプション）
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Gemini TTS デフォルト設定
# =============================================

# デフォルト音声名（Zephyr, Puck, Charon, Aoede, Fenrir, Kore, Perse）
DEFAULT_VOICE_NAME=Aoede

# デフォルト言語コード
DEFAULT_LANGUAGE_CODE=ja-JP

# デフォルト音声エンコーディング（MP3, LINEAR16, OGG_OPUS）
DEFAULT_AUDIO_ENCODING=MP3

# 音声パラメータ
DEFAULT_SPEAKING_RATE=1.0
DEFAULT_PITCH=0.0
DEFAULT_VOLUME_GAIN_DB=0.0

# サービス制限
# =============================================

# 最大テキスト長（文字数）
MAX_TEXT_LENGTH=5000

# リクエストタイムアウト（秒）
REQUEST_TIMEOUT=30

# リトライ設定
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=1
