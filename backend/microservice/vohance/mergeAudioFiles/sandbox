# ### curlコマンドサンプル

# ```bash
# # ヘルスチェック
# curl -X GET https://merge-audio-files-328416367800.asia-northeast1.run.app/health

# # 基本的な音声統合テスト
# curl -X POST https://merge-audio-files-328416367800.asia-northeast1.run.app/merge-audio \
#   -H "Content-Type: application/json" \
#   -d '{
#     "audio_files": [
#       "gs://vohance-sample-videos/sample_audio1.mp3",
#       "gs://vohance-sample-videos/sample_audio2.wav"
