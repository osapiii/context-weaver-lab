#     "buffer_seconds": 2.0,
#     "output_gcs_filepath": "gs://vohance-sample-videos/merged_output.mp3"
#   }'

# # 複数ファイル統合テスト
# curl -X POST https://merge-audio-files-328416367800.asia-northeast1.run.app/merge-audio \
#   -H "Content-Type: application/json" \
