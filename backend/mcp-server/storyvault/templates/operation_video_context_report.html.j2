<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ video.title|text(operation_video_id) }} StoryVault Operation Video Bundle</title>
  <style>
    :root {
      color-scheme: light;
      --ink: #0f172a;
      --muted: #64748b;
      --line: #dbe3ef;
      --panel: #f8fafc;
      --nav: #0f172a;
      --accent: #0f9aa7;
      --soft: #ecfeff;
      --ok: #047857;
      --blue: #0ea5e9;
      --green: #10b981;
      --amber: #f59e0b;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { margin: 0; background: #fff; color: var(--ink); font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; line-height: 1.65; letter-spacing: 0; }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    .layout { display: grid; grid-template-columns: 280px minmax(0, 1fr); min-height: 100vh; }
    .sidebar { position: sticky; top: 0; height: 100vh; overflow: auto; border-right: 1px solid var(--line); background: var(--panel); padding: 22px 18px; }
    .brand { margin: 0; color: var(--muted); font-size: 12px; font-weight: 900; letter-spacing: .12em; text-transform: uppercase; }
    .side-title { margin: 8px 0 18px; color: var(--nav); font-size: 18px; line-height: 1.25; }
    .nav { display: grid; gap: 7px; margin-top: 18px; }
    .nav a { display: block; border-radius: 8px; padding: 9px 10px; color: #334155; font-size: 13px; font-weight: 800; }
    .nav a:hover { background: #fff; text-decoration: none; color: var(--nav); }
    .content { min-width: 0; padding: 30px min(5vw, 54px) 56px; }
    .hero { border-bottom: 1px solid var(--line); padding-bottom: 22px; }
    .eyebrow { margin: 0 0 6px; color: var(--accent); font-size: 13px; font-weight: 900; }
    h1 { margin: 0; color: var(--nav); font-size: clamp(30px, 4vw, 54px); line-height: 1.08; letter-spacing: 0; }
    h2 { margin: 36px 0 12px; padding-top: 10px; color: var(--nav); font-size: 24px; line-height: 1.25; }
    h3 { margin: 18px 0 8px; color: var(--nav); font-size: 17px; }
    p { margin: 0; }
    .summary { margin-top: 12px; max-width: 900px; color: #475569; }
    .grid { display: grid; gap: 14px; }
    .cols-5 { grid-template-columns: repeat(6, minmax(0, 1fr)); }
    .cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .metric, .panel { border: 1px solid var(--line); border-radius: 8px; background: #fff; padding: 15px; }
    .metric { background: var(--panel); }
    .metric span { display: block; color: var(--muted); font-size: 12px; font-weight: 900; }
    .metric strong { display: block; overflow-wrap: anywhere; font-size: 18px; }
    .kv { display: grid; grid-template-columns: 160px minmax(0, 1fr); gap: 9px; font-size: 13px; }
    .kv b { color: var(--muted); }
    .muted { color: var(--muted); }
    .chips { display: flex; flex-wrap: wrap; gap: 6px; }
    .chip { border-radius: 999px; background: var(--soft); color: #0e7490; padding: 3px 9px; font-size: 12px; font-weight: 800; }
    video, img { width: 100%; max-height: 560px; border: 1px solid var(--line); border-radius: 8px; background: #f1f5f9; object-fit: contain; }
    .frames { display: grid; gap: 12px; grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .frame p { margin-top: 5px; color: var(--muted); font-size: 12px; }
    .story { border-left: 4px solid var(--accent); }
    .value-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; margin: 12px 0; }
    .value-card { border: 1px solid var(--line); border-top: 5px solid var(--accent); border-radius: 8px; padding: 14px; background: #fff; min-height: 120px; }
    .value-card.who { border-top-color: var(--blue); }
    .value-card.what { border-top-color: var(--green); }
    .value-card.why { border-top-color: var(--amber); }
    .value-card span { display: inline-flex; gap: 6px; align-items: center; color: var(--muted); font-size: 12px; font-weight: 900; }
    .value-card strong { display: block; margin-top: 8px; font-size: 18px; line-height: 1.45; }
    .evidence-card { border: 1px solid var(--line); border-radius: 8px; padding: 12px; background: var(--panel); margin-top: 10px; }
    .quote { border: 1px solid #bae6fd; border-radius: 8px; background: #f0f9ff; padding: 10px; color: #164e63; }
    .time { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-weight: 800; color: #0f766e; }
    .transcript-list { display: grid; gap: 7px; }
    .transcript-cue { display: grid; grid-template-columns: 150px minmax(0, 1fr); gap: 10px; border: 1px solid var(--line); border-radius: 8px; padding: 10px; background: #fff; }
    .mini-frames { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 8px; margin-top: 10px; }
    .mini-frames img { max-height: 120px; }
    .criteria { margin: 10px 0 0; padding: 0; list-style: none; }
    .criteria li { display: grid; grid-template-columns: 92px minmax(0,1fr); gap: 10px; border-top: 1px solid var(--line); padding: 10px 0; }
    .criteria li:first-child { border-top: 0; }
    .state { color: var(--ok); font-size: 12px; font-weight: 900; text-transform: uppercase; }
    .refs { margin: 0; padding-left: 18px; }
    .refs li { margin: 5px 0; overflow-wrap: anywhere; }
    @media (max-width: 960px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar { position: static; height: auto; }
      .content { padding: 22px 16px 44px; }
      .cols-5, .cols-3, .cols-2, .frames { grid-template-columns: 1fr; }
      .value-grid, .mini-frames, .transcript-cue { grid-template-columns: 1fr; }
      .kv, .criteria li { grid-template-columns: 1fr; gap: 4px; }
    }
  </style>
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <p class="brand">StoryVault Bundle</p>
      <h2 class="side-title">{{ video.title|text(operation_video_id) }}</h2>
      <div class="chips">
        <span class="chip">{{ linked_stories|length }} stories</span>
        <span class="chip">{{ video.screenshots|default([])|length }} screenshots</span>
      </div>
      <nav class="nav" aria-label="Report sections">
        <a href="#overview">Overview</a>
        <a href="#video">Operation Video</a>
        <a href="#clips">Operation Clips</a>
        <a href="#story-candidates">Story Candidates</a>
        <a href="#transcript">Timestamped Transcript</a>
        <a href="#stories">Linked User Stories</a>
        <a href="#evidence">Evidence</a>
        <a href="#assets">Source Assets</a>
        <a href="#knowledge">Knowledge Documents</a>
        <a href="#screenshots">Screenshots</a>
        <a href="#slack">Slack Messages</a>
        <a href="#pull-requests">Pull Requests</a>
      </nav>
    </aside>

    <main class="content">
      <header class="hero" id="overview">
        <p class="eyebrow">Operation video centered context</p>
        <h1>{{ video.title|text(operation_video_id) }}</h1>
        <p class="summary">{{ video.description|text(video.transcriptSummary|text("This report bundles all user stories linked to one operation video.")) }}</p>
      </header>

      <section>
        <h2>Bundle Metrics</h2>
        <div class="grid cols-5">
          <div class="metric"><span>Group</span><strong>{{ video_group.name|text("n/a") }}</strong></div>
          <div class="metric"><span>Stories</span><strong>{{ linked_stories|length }}</strong></div>
          <div class="metric"><span>Evidence</span><strong>{{ evidence|length }}</strong></div>
          <div class="metric"><span>Assets</span><strong>{{ source_assets|length }}</strong></div>
          <div class="metric"><span>Clips</span><strong>{{ video.clips|default([])|length }}</strong></div>
          <div class="metric"><span>Screenshots</span><strong>{{ counts.screenshots|default(video.screenshots|default([])|length) }}</strong></div>
          <div class="metric"><span>Story Candidates</span><strong>{{ video.storyCandidates|default([])|length }}</strong></div>
          <div class="metric"><span>Transcript Cues</span><strong>{{ video.transcriptSegmentCount|default(video.transcriptSegments|default([])|length) }}</strong></div>
          <div class="metric"><span>PRs</span><strong>{{ pull_requests|length }}</strong></div>
          <div class="metric"><span>Slack</span><strong>{{ slack_messages|length }}</strong></div>
          <div class="metric"><span>Knowledge</span><strong>{{ knowledge_documents|length }}</strong></div>
        </div>
      </section>

      <section id="video">
        <h2>Operation Video</h2>
        <div class="panel">
          {% if video.downloadUrl %}
            <video controls preload="metadata" src="{{ video.downloadUrl }}"></video>
            <p class="muted"><a href="{{ video.downloadUrl }}" target="_blank" rel="noopener noreferrer">動画ファイルを開く</a></p>
          {% endif %}
          <div class="grid cols-2" style="margin-top: 14px;">
            <div class="kv"><b>Video ID</b><span>{{ operation_video_id }}</span></div>
            <div class="kv"><b>Group</b><span>{{ video.videoGroup.name|text(video_group.name|text("n/a")) }}</span></div>
            <div class="kv"><b>Recorded at</b><span>{{ video.recordedAt|text("n/a") }}</span></div>
            <div class="kv"><b>Duration</b><span>{{ video.durationMs|format_ms }}</span></div>
            <div class="kv"><b>Transcript provider</b><span>{{ video.transcriptProvider|text("n/a") }}</span></div>
            <div class="kv"><b>Transcript timing</b><span>{{ video.transcriptTimingStatus|text("n/a") }}</span></div>
            <div class="kv"><b>Analysis status</b><span>{{ video.analysisStatus|text("n/a") }}</span></div>
            <div class="kv"><b>Story candidates</b><span>{{ video.storyCandidateCount|default(video.storyCandidates|default([])|length) }}</span></div>
            <div class="kv"><b>GCS path</b><span>{{ video.gcsPath|text("n/a") }}</span></div>
          </div>
          {% if video_group.description %}
            <h3>Group Description</h3>
            <p>{{ video_group.description }}</p>
          {% endif %}
          {% if video.transcriptSummary %}
            <h3>Transcript Summary</h3>
            <p>{{ video.transcriptSummary }}</p>
          {% endif %}
        </div>
      </section>

      <section id="clips">
        <h2>Operation Clips</h2>
        <div class="grid">
          {% for clip in video.clips|default([]) %}
            <article class="panel">
              <h3>{{ clip.id|text("clip") }}{% if clip.fileName %}: {{ clip.fileName }}{% endif %}</h3>
              {% if clip.downloadUrl %}
                <video controls preload="metadata" src="{{ clip.downloadUrl }}"></video>
                <p class="muted"><a href="{{ clip.downloadUrl }}" target="_blank" rel="noopener noreferrer">クリップ動画を開く</a></p>
              {% endif %}
              <div class="grid cols-2" style="margin-top: 14px;">
                <div class="kv"><b>Recorded at</b><span>{{ clip.recordedAt|text("n/a") }}</span></div>
                <div class="kv"><b>Duration</b><span>{{ clip.durationMs|format_ms }}</span></div>
                <div class="kv"><b>Screenshots</b><span>{{ clip.screenshots|default([])|length }}</span></div>
                <div class="kv"><b>Transcript provider</b><span>{{ clip.transcriptProvider|text("n/a") }}</span></div>
                <div class="kv"><b>Transcript timing</b><span>{{ clip.transcriptTimingStatus|text("n/a") }}</span></div>
                <div class="kv"><b>Transcript cues</b><span>{{ clip.transcriptSegmentCount|default(clip.transcriptSegments|default([])|length) }}</span></div>
                <div class="kv"><b>GCS path</b><span>{{ clip.gcsPath|text("n/a") }}</span></div>
              </div>
              {% if clip.transcriptSummary %}
                <h3>Transcript Summary</h3>
                <p>{{ clip.transcriptSummary }}</p>
              {% endif %}
            </article>
          {% else %}
            <div class="panel"><p class="muted">No clips.</p></div>
          {% endfor %}
        </div>
      </section>

      <section id="story-candidates">
        <h2>Extracted Story Candidates</h2>
        <div class="grid">
          {% for candidate in video.storyCandidates|default([]) %}
            <article class="panel story">
              <h3>{{ candidate.storyKey|text(candidate.id|text("story-candidate")) }}: {{ candidate.title|text("Untitled candidate") }}</h3>
              <p class="muted">{{ candidate.summary|text(candidate.userStory|text("No summary recorded.")) }}</p>
              <div class="value-grid">
                <div class="value-card who"><span>Who / 誰が</span><strong>{{ candidate.who|text("n/a") }}</strong></div>
                <div class="value-card what"><span>What / 何をしたいか</span><strong>{{ candidate.what|text("n/a") }}</strong></div>
                <div class="value-card why"><span>Why / 何がうれしいか</span><strong>{{ candidate.why|text("n/a") }}</strong></div>
              </div>
              <div class="chips">
                <span class="chip">根拠 {{ candidate.evidenceCount|default(candidate.evidence|default([])|length) }}</span>
                <span class="chip">字幕 {{ candidate.transcriptCueIds|default([])|length }}</span>
                <span class="chip">キャプチャ {{ candidate.screenshotCount|default(0) }}</span>
                {% if candidate.confidenceScore %}<span class="chip">信頼度 {{ candidate.confidenceScore }}</span>{% endif %}
              </div>
              <ol class="criteria">
                {% for criterion in candidate.acceptanceCriteria|default([]) %}
                  <li><span class="state">完了条件</span><span>{{ criterion }}</span></li>
                {% else %}
                  <li><span class="state">n/a</span><span>No completion criteria recorded.</span></li>
                {% endfor %}
              </ol>
              {% for item in candidate.evidence|default([]) %}
                <div class="evidence-card">
                  <h3>{{ item.title|text("Timestamp evidence") }} <span class="time">{{ item.tRange|format_seconds_range }}</span></h3>
                  <p>{{ item.summary|text("No evidence summary recorded.") }}</p>
                  {% if item.transcriptQuote %}<p class="quote">{{ item.transcriptQuote }}</p>{% endif %}
                  {% if item.transcriptCueIds %}<p class="muted">Cue IDs: {{ item.transcriptCueIds|join(", ") }}</p>{% endif %}
                  <div class="mini-frames">
                    {% for frame in item.screenshots|default([]) %}
                      {% if frame.downloadUrl %}
                        <a href="{{ frame.downloadUrl }}" target="_blank" rel="noopener noreferrer"><img src="{{ frame.downloadUrl }}" alt="{{ frame.id|text('evidence screenshot') }}"></a>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
              {% endfor %}
            </article>
          {% else %}
            <div class="panel"><p class="muted">No extracted story candidates are recorded on this operation video.</p></div>
          {% endfor %}
        </div>
      </section>

      <section id="transcript">
        <h2>Timestamped Transcript</h2>
        <div class="panel">
          <div class="grid cols-3">
            <div class="metric"><span>Provider</span><strong>{{ video.transcriptProvider|text("n/a") }}</strong></div>
            <div class="metric"><span>Timing</span><strong>{{ video.transcriptTimingStatus|text("n/a") }}</strong></div>
            <div class="metric"><span>Cues</span><strong>{{ video.transcriptSegmentCount|default(video.transcriptSegments|default([])|length) }}</strong></div>
          </div>
          <div class="transcript-list" style="margin-top: 14px;">
            {% set transcript_cues = video.transcriptSegments|default([]) %}
            {% for cue in transcript_cues[:120] %}
              <div class="transcript-cue">
                <span class="time">{{ cue.startMs|format_ms }} - {{ cue.endMs|format_ms }}</span>
                <span>{{ cue.text|text("n/a") }}</span>
              </div>
            {% else %}
              <p class="muted">No timestamped transcript cues.</p>
            {% endfor %}
          </div>
          {% if video.transcriptSegmentsTruncated %}<p class="muted">Transcript cues were truncated for MCP response size. Use the original operation video record for the full transcript.</p>{% endif %}
        </div>
      </section>

      <section id="stories">
        <h2>Linked User Stories</h2>
        <div class="grid">
          {% for story in linked_stories %}
            <article class="panel story">
              <h3>{{ story.storyKey|text(story.id) }}: {{ story.title|text("Untitled story") }}</h3>
              <p>{{ story.userStory|text(story.summary|text("No user story recorded.")) }}</p>
              <div class="chips" style="margin-top: 10px;">
                {% for evidence_id in story.evidenceIds|default([]) %}
                  <span class="chip">{{ evidence_id }}</span>
                {% endfor %}
              </div>
              <ol class="criteria">
                {% for criterion in story.acceptanceCriteria|default([]) %}
                  <li>
                    <span class="state">{{ criterion.state|text("unknown") }}</span>
                    <span>{{ criterion.text|text("Untitled criterion") }}{% if criterion.evidenceIds %}<br><span class="muted">evidence: {{ criterion.evidenceIds|join(", ") }}</span>{% endif %}</span>
                  </li>
                {% else %}
                  <li><span class="state">n/a</span><span>No acceptance criteria recorded.</span></li>
                {% endfor %}
              </ol>
            </article>
          {% else %}
            <div class="panel"><p class="muted">No user stories are linked to this operation video.</p></div>
          {% endfor %}
        </div>
      </section>

      <section id="evidence">
        <h2>Evidence</h2>
        <div class="grid cols-2">
          {% for item in evidence %}
            <article class="panel">
              <h3>{{ item.title|text(item.id) }}</h3>
              <div class="kv"><b>Evidence ID</b><span>{{ item.id|text("n/a") }}</span></div>
              <div class="kv"><b>Story</b><span>{{ item.storyKey|text(item.storyId|text("n/a")) }}</span></div>
              <div class="kv"><b>Excerpt</b><span>{{ item.excerpt|text("n/a") }}</span></div>
              <div class="kv"><b>Source asset</b><span>{{ item.sourceAssetId|text("n/a") }}</span></div>
            </article>
          {% else %}
            <div class="panel"><p class="muted">No evidence is linked.</p></div>
          {% endfor %}
        </div>
      </section>

      <section id="assets">
        <h2>Source Assets</h2>
        <div class="panel">
          <ul class="refs">
            {% for asset in source_assets %}
              <li><strong>{{ asset.id|text("source_asset") }}</strong>{% if asset.downloadUrl %}<br><a href="{{ asset.downloadUrl }}" target="_blank" rel="noopener noreferrer">{{ asset.downloadUrl }}</a>{% endif %}{% if asset.gcsPath %}<br><span class="muted">{{ asset.gcsPath }}</span>{% endif %}</li>
            {% else %}
              <li class="muted">No source asset refs.</li>
            {% endfor %}
          </ul>
        </div>
      </section>

      <section id="knowledge">
        <h2>Knowledge Documents</h2>
        <div class="grid cols-2">
          {% for doc in knowledge_documents %}
            <article class="panel">
              <h3>{{ doc.displayName|text(doc.documentId|text(doc.name|text("Knowledge"))) }}</h3>
              <div class="kv"><b>FileSpace</b><span>{{ doc.fileSpaceId|text("n/a") }}</span></div>
              <div class="kv"><b>MIME</b><span>{{ doc.mimeType|text("n/a") }}</span></div>
              <div class="kv"><b>Score</b><span>{{ doc.relevanceScore|text("n/a") }}</span></div>
              <div class="kv"><b>Reason</b><span>{{ doc.reason|text("n/a") }}</span></div>
              {% if doc.downloadUrl %}<div class="kv"><b>Download</b><span><a href="{{ doc.downloadUrl }}" target="_blank" rel="noopener noreferrer">{{ doc.downloadUrl }}</a></span></div>{% endif %}
              {% if doc.gcsPath or doc.gcsUrl %}<div class="kv"><b>GCS</b><span>{{ doc.gcsPath|text(doc.gcsUrl|text("n/a")) }}</span></div>{% endif %}
            </article>
          {% else %}
            <div class="panel"><p class="muted">No knowledge document refs.</p></div>
          {% endfor %}
        </div>
      </section>

      <section id="screenshots">
        <h2>Screenshots</h2>
        <div class="frames">
          {% set frames = video.screenshots|default([]) %}
          {% for frame in frames[:30] %}
            <figure class="frame">
              {% if frame.downloadUrl %}
                <a href="{{ frame.downloadUrl }}" target="_blank" rel="noopener noreferrer"><img src="{{ frame.downloadUrl }}" alt="{{ frame.id|text('operation screenshot') }}"></a>
              {% endif %}
              <p>{{ frame.id|text("frame") }} / {{ frame.timestampMs|format_ms }}</p>
            </figure>
          {% else %}
            <div class="panel"><p class="muted">No screenshots.</p></div>
          {% endfor %}
        </div>
      </section>

      <section id="pull-requests">
        <h2>GitHub Pull Requests</h2>
        <div class="panel">
          <ul class="refs">
            {% for pr in pull_requests %}
              <li>{{ pr.repoFullName|text("repo") }} PR {{ pr.number|text("n/a") }}: <a href="{{ pr.htmlUrl }}" target="_blank" rel="noopener noreferrer">{{ pr.title|text("n/a") }}</a></li>
            {% else %}
              <li class="muted">No GitHub pull request refs.</li>
            {% endfor %}
          </ul>
        </div>
      </section>

      <section id="slack">
        <h2>Slack Messages</h2>
        <div class="grid cols-2">
          {% for message in slack_messages %}
            <article class="panel">
              <h3>#{{ message.channelName|text(message.channelId|text("slack")) }}</h3>
              <div class="kv"><b>Team</b><span>{{ message.teamName|text(message.teamId|text("n/a")) }}</span></div>
              <div class="kv"><b>Author</b><span>{{ message.author|text("unknown") }}</span></div>
              <div class="kv"><b>Posted</b><span>{{ message.postedAt|text(message.messageTs|text("n/a")) }}</span></div>
              <div class="kv"><b>Score</b><span>{{ message.relevanceScore|text("n/a") }}</span></div>
              <div class="kv"><b>Reason</b><span>{{ message.reason|text("n/a") }}</span></div>
              <p style="margin-top: 10px;">{{ message.text|text("n/a") }}</p>
              {% if message.permalink %}<p class="muted" style="margin-top: 10px;"><a href="{{ message.permalink }}" target="_blank" rel="noopener noreferrer">Slackで開く</a></p>{% endif %}
            </article>
          {% else %}
            <div class="panel"><p class="muted">No Slack message refs.</p></div>
          {% endfor %}
        </div>
      </section>
    </main>
  </div>
</body>
</html>
