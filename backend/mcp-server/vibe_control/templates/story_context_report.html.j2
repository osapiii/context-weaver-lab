<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ story_key }} StoryVault Story Context</title>
  <style>
    :root {
      color-scheme: light;
      --ink: #0f172a;
      --muted: #64748b;
      --line: #dbe3ef;
      --panel: #f8fafc;
      --soft: #eef2ff;
      --accent: #4f46e5;
      --ok: #047857;
      --warn: #b45309;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: #ffffff;
      color: var(--ink);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      line-height: 1.65;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    html { scroll-behavior: smooth; }
    .layout { display: grid; grid-template-columns: 280px minmax(0, 1fr); min-height: 100vh; }
    .sidebar {
      position: sticky;
      top: 0;
      height: 100vh;
      overflow: auto;
      border-right: 1px solid var(--line);
      background: var(--panel);
      padding: 22px 18px;
    }
    .side-title { margin: 8px 0 16px; font-size: 18px; line-height: 1.25; }
    .nav { display: grid; gap: 7px; margin-top: 18px; }
    .nav a {
      display: block;
      border-radius: 8px;
      padding: 9px 10px;
      color: #334155;
      font-size: 13px;
      font-weight: 800;
    }
    .nav a:hover { background: #fff; text-decoration: none; color: var(--ink); }
    .page { min-width: 0; max-width: 1180px; margin: 0 auto; padding: 28px 24px 48px; }
    .topbar {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 18px;
      border-bottom: 1px solid var(--line);
      padding-bottom: 18px;
    }
    .eyebrow { margin: 0 0 4px; color: var(--muted); font-size: 12px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; }
    h1 { margin: 0; font-size: clamp(28px, 4vw, 46px); line-height: 1.12; letter-spacing: 0; }
    h2 { margin: 34px 0 12px; font-size: 22px; line-height: 1.25; }
    h3 { margin: 18px 0 8px; font-size: 16px; }
    p { margin: 0; }
    .summary { margin-top: 12px; max-width: 820px; color: #334155; }
    .grid { display: grid; gap: 14px; }
    .cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .metric {
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 12px;
      background: var(--panel);
      min-width: 0;
    }
    .metric span { display: block; color: var(--muted); font-size: 12px; font-weight: 700; }
    .metric strong { display: block; overflow-wrap: anywhere; font-size: 15px; }
    .chips { display: flex; flex-wrap: wrap; gap: 6px; }
    .chip {
      display: inline-flex;
      align-items: center;
      max-width: 100%;
      border-radius: 999px;
      background: var(--soft);
      color: #3730a3;
      padding: 3px 9px;
      font-size: 12px;
      font-weight: 700;
      overflow-wrap: anywhere;
    }
    .panel {
      border: 1px solid var(--line);
      border-radius: 8px;
      background: #fff;
      padding: 16px;
    }
    .muted { color: var(--muted); }
    .section-note { margin: -4px 0 14px; color: var(--muted); font-size: 13px; }
    .criteria { margin: 0; padding: 0; list-style: none; }
    .criteria li {
      display: grid;
      grid-template-columns: 92px minmax(0, 1fr);
      gap: 12px;
      border-top: 1px solid var(--line);
      padding: 12px 0;
    }
    .criteria li:first-child { border-top: 0; padding-top: 0; }
    .state { color: var(--ok); font-size: 12px; font-weight: 800; text-transform: uppercase; }
    .evidence-card { display: grid; gap: 8px; border-top: 1px solid var(--line); padding: 14px 0; }
    .evidence-card:first-child { border-top: 0; padding-top: 0; }
    .kv { display: grid; grid-template-columns: 150px minmax(0, 1fr); gap: 8px; font-size: 13px; }
    .kv b { color: var(--muted); }
    pre {
      margin: 10px 0 0;
      max-height: 420px;
      overflow: auto;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: #0f172a;
      color: #e2e8f0;
      padding: 14px;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
      font-size: 12px;
      line-height: 1.55;
    }
    .media {
      display: grid;
      gap: 14px;
      grid-template-columns: minmax(0, 1fr);
      border-top: 1px solid var(--line);
      padding-top: 16px;
      margin-top: 16px;
    }
    video, img {
      width: 100%;
      max-height: 520px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: #f1f5f9;
      object-fit: contain;
    }
    .frames { display: grid; gap: 12px; grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .frame p { margin-top: 5px; color: var(--muted); font-size: 12px; }
    .refs { margin: 0; padding-left: 18px; }
    .refs li { margin: 5px 0; overflow-wrap: anywhere; }
    .footer {
      margin-top: 36px;
      border-top: 1px solid var(--line);
      padding-top: 16px;
      color: var(--muted);
      font-size: 13px;
    }
    @media (max-width: 860px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar { position: static; height: auto; }
      .page { padding: 20px 14px 40px; }
      .topbar, .cols-4, .cols-3, .cols-2, .frames { grid-template-columns: 1fr; display: grid; }
      .criteria li, .kv { grid-template-columns: 1fr; gap: 4px; }
    }
  </style>
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <p class="eyebrow">Story Context</p>
      <h2 class="side-title">{{ story_key }}</h2>
      <div class="chips">
        {% for evidence_id in evidence_ids[:3] %}
          <span class="chip">{{ evidence_id }}</span>
        {% endfor %}
      </div>
      <nav class="nav" aria-label="Report sections">
        <a href="#overview">Overview</a>
        <a href="#story">User Story</a>
        <a href="#acceptance-criteria">Acceptance Criteria</a>
        <a href="#evidence">Evidence</a>
        <a href="#source-assets">Source Assets</a>
        <a href="#media">Media</a>
        <a href="#knowledge">Knowledge Documents</a>
        <a href="#references">References</a>
      </nav>
    </aside>
  <main class="page">
    <header class="topbar">
      <div>
        <p class="eyebrow">StoryVault Story Context Report</p>
        <h1>{{ story_key }}</h1>
        <p class="summary">{{ story.title|text("Untitled story") }}</p>
      </div>
      <div class="chips" aria-label="evidence ids">
        {% for evidence_id in evidence_ids %}
          <span class="chip">{{ evidence_id }}</span>
        {% else %}
          <span class="chip">No evidence IDs</span>
        {% endfor %}
      </div>
    </header>

    <section id="overview">
      <h2>基本情報</h2>
      <div class="grid cols-4">
        <div class="metric"><span>Application</span><strong>{{ application.name|text(application.id) }}</strong></div>
        <div class="metric"><span>Repo</span><strong>{{ application.repoFullName|text("n/a") }}</strong></div>
        <div class="metric"><span>Status</span><strong>{{ story.status|text("n/a") }}</strong></div>
        <div class="metric"><span>Review</span><strong>{{ story.reviewState|text("n/a") }}</strong></div>
      </div>
      <div class="grid cols-4" style="margin-top: 14px;">
        <div class="metric"><span>Source Assets</span><strong>{{ counts.sourceAssets|default(source_asset_refs|length) }}</strong></div>
        <div class="metric"><span>Videos</span><strong>{{ counts.operationVideos|default(operation_videos|length) }}</strong></div>
        <div class="metric"><span>Screenshots</span><strong>{{ counts.screenshots|default(screenshot_count) }}</strong></div>
        <div class="metric"><span>Knowledge</span><strong>{{ counts.knowledgeDocuments|default(knowledge_documents|length) }}</strong></div>
      </div>
    </section>

    <section id="story" class="grid cols-2">
      <div>
        <h2>ユーザーストーリー</h2>
        <div class="panel">
          <p>{{ story.userStory|text("No user story recorded.") }}</p>
          {% if story.summary %}
            <p class="muted" style="margin-top: 12px;">{{ story.summary }}</p>
          {% endif %}
          {% if labels %}
            <div class="chips" style="margin-top: 12px;">
              {% for label in labels %}<span class="chip">{{ label }}</span>{% endfor %}
            </div>
          {% endif %}
        </div>
      </div>
      <div>
        <h2>Capability</h2>
        <div class="panel">
          {% if capability %}
            <div class="kv"><b>Key</b><span>{{ capability.capabilityKey|text("n/a") }}</span></div>
            <div class="kv"><b>Name</b><span>{{ capability.name|text("n/a") }}</span></div>
            <div class="kv"><b>Domain</b><span>{{ capability.domain|text("n/a") }}</span></div>
            <div class="kv"><b>Summary</b><span>{{ capability.summary|text("n/a") }}</span></div>
          {% else %}
            <p class="muted">No capability is linked.</p>
          {% endif %}
        </div>
      </div>
    </section>

    <section id="acceptance-criteria">
      <h2>受け入れ条件</h2>
      <div class="panel">
        <ol class="criteria">
          {% for criterion in criteria %}
            <li>
              <span class="state">{{ criterion.state|text("unknown") }}</span>
              <span>
                {{ criterion.text|text("Untitled criterion") }}
                {% if criterion.evidenceIds %}
                  <br><span class="muted">evidence: {{ criterion.evidenceIds|join(", ") }}</span>
                {% endif %}
              </span>
            </li>
          {% else %}
            <li><span class="state">n/a</span><span>No acceptance criteria recorded.</span></li>
          {% endfor %}
        </ol>
      </div>
    </section>

    <section id="evidence">
      <h2>証跡</h2>
      <p class="section-note">実装計画、PR本文、コミットメモに残すべき evidence ID です。</p>
      <div class="panel">
        {% for item in evidence %}
          <article class="evidence-card">
            <h3>{{ item.title|text(item.id) }}</h3>
            <div class="kv"><b>Evidence ID</b><span>{{ item.id|text("n/a") }}</span></div>
            <div class="kv"><b>Type</b><span>{{ item.type|text("n/a") }}</span></div>
            <div class="kv"><b>Excerpt</b><span>{{ item.excerpt|text("n/a") }}</span></div>
            <div class="kv"><b>Observed action</b><span>{{ item.observedUserAction|text("n/a") }}</span></div>
            <div class="kv"><b>UI surface</b><span>{{ item.observedUiSurface|text("n/a") }}</span></div>
            <div class="kv"><b>Source asset</b><span>{{ item.sourceAssetId|text("n/a") }}</span></div>
            {% if item.sourceUrl %}<div class="kv"><b>Source URL</b><span><a href="{{ item.sourceUrl }}" target="_blank" rel="noopener noreferrer">{{ item.sourceUrl }}</a></span></div>{% endif %}
          </article>
        {% else %}
          <p class="muted">No evidence is linked to this story.</p>
        {% endfor %}
      </div>
    </section>

    <section id="source-assets">
      <h2>Source Assets</h2>
      <div class="grid">
        {% for asset in source_assets %}
          <article class="panel">
            <h3>{{ asset.title|text(asset.id) }}</h3>
            <div class="kv"><b>Type</b><span>{{ asset.sourceType|text("n/a") }}</span></div>
            <div class="kv"><b>URI</b><span>{{ asset.uri|text("n/a") }}</span></div>
            <div class="kv"><b>GCS path</b><span>{{ asset.gcsPath|text("n/a") }}</span></div>
            <div class="kv"><b>Storage path</b><span>{{ asset.storagePath|text("n/a") }}</span></div>
            {% if asset.markdownBody %}
              <pre>{{ asset.markdownBody }}</pre>
            {% elif asset.markdownBodyError %}
              <p class="muted">Markdown body error: {{ asset.markdownBodyError }}</p>
            {% endif %}
          </article>
        {% else %}
          <div class="panel"><p class="muted">No source assets were resolved.</p></div>
        {% endfor %}
      </div>
    </section>

    <section id="media">
      <h2>メディア</h2>
      <div class="grid">
        {% for video in operation_videos %}
          <article class="panel">
            <h3>{{ video.title|text(video.id) }}</h3>
            {% if video.downloadUrl %}
              <video controls preload="metadata" src="{{ video.downloadUrl }}"></video>
              <p class="muted"><a href="{{ video.downloadUrl }}" target="_blank" rel="noopener noreferrer">動画ファイルを開く</a></p>
            {% else %}
              <p class="muted">{{ video.gcsPath|text("No video URL") }}</p>
            {% endif %}
            {% set screenshots = video.screenshots if video.screenshots is sequence else [] %}
            {% if screenshots %}
              <div class="media">
                <h3>スクリーンショット</h3>
                <div class="frames">
                  {% for frame in screenshots[:24] %}
                    <figure class="frame">
                      {% if frame.downloadUrl %}
                        <a href="{{ frame.downloadUrl }}" target="_blank" rel="noopener noreferrer">
                          <img src="{{ frame.downloadUrl }}" alt="{{ frame.id|text('operation screenshot') }}">
                        </a>
                      {% endif %}
                      <p>{{ frame.id|text("frame") }} / {{ frame.timestampMs|format_ms }}</p>
                    </figure>
                  {% endfor %}
                </div>
              </div>
            {% endif %}
          </article>
        {% else %}
          <div class="panel"><p class="muted">No operation video refs.</p></div>
        {% endfor %}
      </div>
    </section>

    <section id="knowledge">
      <h2>Knowledge Documents</h2>
      <div class="grid">
        {% for doc in knowledge_documents %}
          <article class="panel">
            <h3>{{ doc.displayName|text(doc.documentId|text(doc.name|text("Knowledge"))) }}</h3>
            <div class="kv"><b>FileSpace</b><span>{{ doc.fileSpaceId|text("n/a") }}</span></div>
            <div class="kv"><b>MIME</b><span>{{ doc.mimeType|text("n/a") }}</span></div>
            <div class="kv"><b>Score</b><span>{{ doc.relevanceScore|text("n/a") }}</span></div>
            <div class="kv"><b>Reason</b><span>{{ doc.reason|text("n/a") }}</span></div>
            {% if doc.downloadUrl %}<div class="kv"><b>Download</b><span><a href="{{ doc.downloadUrl }}" target="_blank" rel="noopener noreferrer">{{ doc.downloadUrl }}</a></span></div>{% endif %}
            {% if doc.gcsPath or doc.gcsUrl %}<div class="kv"><b>GCS</b><span>{{ doc.gcsPath|text(doc.gcsUrl|text("n/a")) }}</span></div>{% endif %}
          </article>
        {% else %}
          <div class="panel"><p class="muted">No knowledge document refs.</p></div>
        {% endfor %}
      </div>
    </section>

    <section id="references" class="grid cols-2">
      <div>
        <h2>元ファイル</h2>
        <div class="panel">
          <ul class="refs">
            {% for asset in source_asset_refs %}
              <li>
                <strong>{{ asset.id|text("source_asset") }}</strong>
                {% if asset.downloadUrl %}<br><a href="{{ asset.downloadUrl }}" target="_blank" rel="noopener noreferrer">{{ asset.downloadUrl }}</a>{% endif %}
                {% if asset.gcsPath %}<br><span class="muted">{{ asset.gcsPath }}</span>{% endif %}
              </li>
            {% else %}
              <li class="muted">No source asset file refs.</li>
            {% endfor %}
          </ul>
        </div>
      </div>
      <div>
        <h2>GitHub PR</h2>
        <div class="panel">
          <ul class="refs">
            {% for pr in pull_requests %}
              <li>
                <strong>{{ pr.repoFullName|text("repo") }} #{{ pr.number|text("n/a") }}</strong><br>
                {% if pr.htmlUrl %}<a href="{{ pr.htmlUrl }}" target="_blank" rel="noopener noreferrer">{{ pr.title|text(pr.htmlUrl) }}</a>{% else %}{{ pr.title|text("Untitled PR") }}{% endif %}
              </li>
            {% else %}
              <li class="muted">No GitHub pull request refs.</li>
            {% endfor %}
          </ul>
        </div>
      </div>
    </section>

    <footer class="footer">
      <p>Read-only MCP report. Do not write plans or patches back through this MCP server. Preserve evidence IDs in local implementation plans and PR notes.</p>
      {% if manifest.generatedAt %}<p>Generated at: {{ manifest.generatedAt }}</p>{% endif %}
      {% if manifest.signedUrlExpiresAt %}<p>Signed URLs expire at: {{ manifest.signedUrlExpiresAt }}</p>{% endif %}
    </footer>
  </main>
  </div>
</body>
</html>
