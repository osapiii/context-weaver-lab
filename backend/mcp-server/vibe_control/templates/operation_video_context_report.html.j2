<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ video.title|text(operation_video_id) }} StoryVault Operation Video Bundle</title>
  <style>
    :root {
      color-scheme: light;
      --ink: #0f172a;
      --muted: #64748b;
      --line: #dbe3ef;
      --panel: #f8fafc;
      --nav: #0f172a;
      --accent: #0f9aa7;
      --soft: #ecfeff;
      --ok: #047857;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { margin: 0; background: #fff; color: var(--ink); font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; line-height: 1.65; letter-spacing: 0; }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    .layout { display: grid; grid-template-columns: 280px minmax(0, 1fr); min-height: 100vh; }
    .sidebar { position: sticky; top: 0; height: 100vh; overflow: auto; border-right: 1px solid var(--line); background: var(--panel); padding: 22px 18px; }
    .brand { margin: 0; color: var(--muted); font-size: 12px; font-weight: 900; letter-spacing: .12em; text-transform: uppercase; }
    .side-title { margin: 8px 0 18px; color: var(--nav); font-size: 18px; line-height: 1.25; }
    .nav { display: grid; gap: 7px; margin-top: 18px; }
    .nav a { display: block; border-radius: 8px; padding: 9px 10px; color: #334155; font-size: 13px; font-weight: 800; }
    .nav a:hover { background: #fff; text-decoration: none; color: var(--nav); }
    .content { min-width: 0; padding: 30px min(5vw, 54px) 56px; }
    .hero { border-bottom: 1px solid var(--line); padding-bottom: 22px; }
    .eyebrow { margin: 0 0 6px; color: var(--accent); font-size: 13px; font-weight: 900; }
    h1 { margin: 0; color: var(--nav); font-size: clamp(30px, 4vw, 54px); line-height: 1.08; letter-spacing: 0; }
    h2 { margin: 36px 0 12px; padding-top: 10px; color: var(--nav); font-size: 24px; line-height: 1.25; }
    h3 { margin: 18px 0 8px; color: var(--nav); font-size: 17px; }
    p { margin: 0; }
    .summary { margin-top: 12px; max-width: 900px; color: #475569; }
    .grid { display: grid; gap: 14px; }
    .cols-5 { grid-template-columns: repeat(6, minmax(0, 1fr)); }
    .cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .metric, .panel { border: 1px solid var(--line); border-radius: 8px; background: #fff; padding: 15px; }
    .metric { background: var(--panel); }
    .metric span { display: block; color: var(--muted); font-size: 12px; font-weight: 900; }
    .metric strong { display: block; overflow-wrap: anywhere; font-size: 18px; }
    .kv { display: grid; grid-template-columns: 160px minmax(0, 1fr); gap: 9px; font-size: 13px; }
    .kv b { color: var(--muted); }
    .muted { color: var(--muted); }
    .chips { display: flex; flex-wrap: wrap; gap: 6px; }
    .chip { border-radius: 999px; background: var(--soft); color: #0e7490; padding: 3px 9px; font-size: 12px; font-weight: 800; }
    video, img { width: 100%; max-height: 560px; border: 1px solid var(--line); border-radius: 8px; background: #f1f5f9; object-fit: contain; }
    .frames { display: grid; gap: 12px; grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .frame p { margin-top: 5px; color: var(--muted); font-size: 12px; }
    .story { border-left: 4px solid var(--accent); }
    .criteria { margin: 10px 0 0; padding: 0; list-style: none; }
    .criteria li { display: grid; grid-template-columns: 92px minmax(0,1fr); gap: 10px; border-top: 1px solid var(--line); padding: 10px 0; }
    .criteria li:first-child { border-top: 0; }
    .state { color: var(--ok); font-size: 12px; font-weight: 900; text-transform: uppercase; }
    .refs { margin: 0; padding-left: 18px; }
    .refs li { margin: 5px 0; overflow-wrap: anywhere; }
    @media (max-width: 960px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar { position: static; height: auto; }
      .content { padding: 22px 16px 44px; }
      .cols-5, .cols-3, .cols-2, .frames { grid-template-columns: 1fr; }
      .kv, .criteria li { grid-template-columns: 1fr; gap: 4px; }
    }
  </style>
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <p class="brand">StoryVault Bundle</p>
      <h2 class="side-title">{{ video.title|text(operation_video_id) }}</h2>
      <div class="chips">
        <span class="chip">{{ linked_stories|length }} stories</span>
        <span class="chip">{{ video.screenshots|default([])|length }} screenshots</span>
      </div>
      <nav class="nav" aria-label="Report sections">
        <a href="#overview">Overview</a>
        <a href="#video">Operation Video</a>
        <a href="#stories">Linked User Stories</a>
        <a href="#evidence">Evidence</a>
        <a href="#assets">Source Assets</a>
        <a href="#knowledge">Knowledge Documents</a>
        <a href="#screenshots">Screenshots</a>
        <a href="#pull-requests">Pull Requests</a>
      </nav>
    </aside>

    <main class="content">
      <header class="hero" id="overview">
        <p class="eyebrow">Operation video centered context</p>
        <h1>{{ video.title|text(operation_video_id) }}</h1>
        <p class="summary">{{ video.description|text(video.transcriptSummary|text("This report bundles all user stories linked to one operation video.")) }}</p>
      </header>

      <section>
        <h2>Bundle Metrics</h2>
        <div class="grid cols-5">
          <div class="metric"><span>Group</span><strong>{{ video_group.name|text("n/a") }}</strong></div>
          <div class="metric"><span>Stories</span><strong>{{ linked_stories|length }}</strong></div>
          <div class="metric"><span>Evidence</span><strong>{{ evidence|length }}</strong></div>
          <div class="metric"><span>Assets</span><strong>{{ source_assets|length }}</strong></div>
          <div class="metric"><span>Screenshots</span><strong>{{ video.screenshots|default([])|length }}</strong></div>
          <div class="metric"><span>PRs</span><strong>{{ pull_requests|length }}</strong></div>
          <div class="metric"><span>Knowledge</span><strong>{{ knowledge_documents|length }}</strong></div>
        </div>
      </section>

      <section id="video">
        <h2>Operation Video</h2>
        <div class="panel">
          {% if video.downloadUrl %}
            <video controls preload="metadata" src="{{ video.downloadUrl }}"></video>
            <p class="muted"><a href="{{ video.downloadUrl }}" target="_blank" rel="noopener noreferrer">動画ファイルを開く</a></p>
          {% endif %}
          <div class="grid cols-2" style="margin-top: 14px;">
            <div class="kv"><b>Video ID</b><span>{{ operation_video_id }}</span></div>
            <div class="kv"><b>Group</b><span>{{ video.videoGroup.name|text(video_group.name|text("n/a")) }}</span></div>
            <div class="kv"><b>Recorded at</b><span>{{ video.recordedAt|text("n/a") }}</span></div>
            <div class="kv"><b>Duration</b><span>{{ video.durationMs|format_ms }}</span></div>
            <div class="kv"><b>GCS path</b><span>{{ video.gcsPath|text("n/a") }}</span></div>
          </div>
          {% if video_group.description %}
            <h3>Group Description</h3>
            <p>{{ video_group.description }}</p>
          {% endif %}
          {% if video.transcriptSummary %}
            <h3>Transcript Summary</h3>
            <p>{{ video.transcriptSummary }}</p>
          {% endif %}
        </div>
      </section>

      <section id="stories">
        <h2>Linked User Stories</h2>
        <div class="grid">
          {% for story in linked_stories %}
            <article class="panel story">
              <h3>{{ story.storyKey|text(story.id) }}: {{ story.title|text("Untitled story") }}</h3>
              <p>{{ story.userStory|text(story.summary|text("No user story recorded.")) }}</p>
              <div class="chips" style="margin-top: 10px;">
                {% for evidence_id in story.evidenceIds|default([]) %}
                  <span class="chip">{{ evidence_id }}</span>
                {% endfor %}
              </div>
              <ol class="criteria">
                {% for criterion in story.acceptanceCriteria|default([]) %}
                  <li>
                    <span class="state">{{ criterion.state|text("unknown") }}</span>
                    <span>{{ criterion.text|text("Untitled criterion") }}{% if criterion.evidenceIds %}<br><span class="muted">evidence: {{ criterion.evidenceIds|join(", ") }}</span>{% endif %}</span>
                  </li>
                {% else %}
                  <li><span class="state">n/a</span><span>No acceptance criteria recorded.</span></li>
                {% endfor %}
              </ol>
            </article>
          {% else %}
            <div class="panel"><p class="muted">No user stories are linked to this operation video.</p></div>
          {% endfor %}
        </div>
      </section>

      <section id="evidence">
        <h2>Evidence</h2>
        <div class="grid cols-2">
          {% for item in evidence %}
            <article class="panel">
              <h3>{{ item.title|text(item.id) }}</h3>
              <div class="kv"><b>Evidence ID</b><span>{{ item.id|text("n/a") }}</span></div>
              <div class="kv"><b>Story</b><span>{{ item.storyKey|text(item.storyId|text("n/a")) }}</span></div>
              <div class="kv"><b>Excerpt</b><span>{{ item.excerpt|text("n/a") }}</span></div>
              <div class="kv"><b>Source asset</b><span>{{ item.sourceAssetId|text("n/a") }}</span></div>
            </article>
          {% else %}
            <div class="panel"><p class="muted">No evidence is linked.</p></div>
          {% endfor %}
        </div>
      </section>

      <section id="assets">
        <h2>Source Assets</h2>
        <div class="panel">
          <ul class="refs">
            {% for asset in source_assets %}
              <li><strong>{{ asset.id|text("source_asset") }}</strong>{% if asset.downloadUrl %}<br><a href="{{ asset.downloadUrl }}" target="_blank" rel="noopener noreferrer">{{ asset.downloadUrl }}</a>{% endif %}{% if asset.gcsPath %}<br><span class="muted">{{ asset.gcsPath }}</span>{% endif %}</li>
            {% else %}
              <li class="muted">No source asset refs.</li>
            {% endfor %}
          </ul>
        </div>
      </section>

      <section id="knowledge">
        <h2>Knowledge Documents</h2>
        <div class="grid cols-2">
          {% for doc in knowledge_documents %}
            <article class="panel">
              <h3>{{ doc.displayName|text(doc.documentId|text(doc.name|text("Knowledge"))) }}</h3>
              <div class="kv"><b>FileSpace</b><span>{{ doc.fileSpaceId|text("n/a") }}</span></div>
              <div class="kv"><b>MIME</b><span>{{ doc.mimeType|text("n/a") }}</span></div>
              <div class="kv"><b>Score</b><span>{{ doc.relevanceScore|text("n/a") }}</span></div>
              <div class="kv"><b>Reason</b><span>{{ doc.reason|text("n/a") }}</span></div>
              {% if doc.downloadUrl %}<div class="kv"><b>Download</b><span><a href="{{ doc.downloadUrl }}" target="_blank" rel="noopener noreferrer">{{ doc.downloadUrl }}</a></span></div>{% endif %}
              {% if doc.gcsPath or doc.gcsUrl %}<div class="kv"><b>GCS</b><span>{{ doc.gcsPath|text(doc.gcsUrl|text("n/a")) }}</span></div>{% endif %}
            </article>
          {% else %}
            <div class="panel"><p class="muted">No knowledge document refs.</p></div>
          {% endfor %}
        </div>
      </section>

      <section id="screenshots">
        <h2>Screenshots</h2>
        <div class="frames">
          {% set frames = video.screenshots|default([]) %}
          {% for frame in frames[:30] %}
            <figure class="frame">
              {% if frame.downloadUrl %}
                <a href="{{ frame.downloadUrl }}" target="_blank" rel="noopener noreferrer"><img src="{{ frame.downloadUrl }}" alt="{{ frame.id|text('operation screenshot') }}"></a>
              {% endif %}
              <p>{{ frame.id|text("frame") }} / {{ frame.timestampMs|format_ms }}</p>
            </figure>
          {% else %}
            <div class="panel"><p class="muted">No screenshots.</p></div>
          {% endfor %}
        </div>
      </section>

      <section id="pull-requests">
        <h2>GitHub Pull Requests</h2>
        <div class="panel">
          <ul class="refs">
            {% for pr in pull_requests %}
              <li>{{ pr.repoFullName|text("repo") }} PR {{ pr.number|text("n/a") }}: <a href="{{ pr.htmlUrl }}" target="_blank" rel="noopener noreferrer">{{ pr.title|text("n/a") }}</a></li>
            {% else %}
              <li class="muted">No GitHub pull request refs.</li>
            {% endfor %}
          </ul>
        </div>
      </section>
    </main>
  </div>
</body>
</html>
