# Copy to .env.<project-alias> (gitignored) for Firebase Functions deploy env injection.
# Do not commit real secrets.

# Callable auth email sender (send_admin_sign_in_link)
SEND_MAIL_SERVICE_URL=https://send-mail-xxxxx-an.a.run.app
AI_STUDIO_APP_NAME=StoryVault
AUTH_EMAIL_LINK_ALLOWED_HOSTS=storyvault-dev.web.app,storyvault-dev.firebaseapp.com,localhost
EN_AISTUDIO_APP_BASE_URL=https://storyvault-dev.web.app

# Dev-only auth bypass (custom token sign-in). Keep project allowlist narrow.
DEV_AUTH_BYPASS_PROJECT_IDS=storyvault-dev
DEV_AUTH_BYPASS_EMAILS=super@enostech.co.jp

# ADK invoke trigger (on_adk_invoke_request_created)
EN_AISTUDIO_ADK_AGENT_URL=https://en-aistudio-adk-agent-mdgjayj74q-an.a.run.app
EN_AISTUDIO_ADK_STORYVAULT_ZAPPING_ANALYSIS_URL=
EN_AISTUDIO_ADK_STORYVAULT_CAPABILITY_STRUCTURING_URL=
EN_AISTUDIO_ADK_STORYVAULT_STORY_GENERATION_URL=
ADK_INTERNAL_INVOKE_SECRET=generate-with-openssl-rand-hex-32

# Context Store Cloud Run for FileSpace RequestDocs
CONTEXT_STORE_SERVICE_URL=https://context-store-xxxxx-uc.a.run.app

# StoryVault video generation Cloud Run workers
STORYVAULT_VIDEO_AI_SECTIONING_URL=https://storyvault-ai-video-sectioning-xxxxx-an.a.run.app
STORYVAULT_VIDEO_SPLIT_BY_TIMESTAMPS_URL=https://storyvault-split-video-by-timestamps-xxxxx-an.a.run.app
STORYVAULT_VIDEO_TRANSCRIBE_AUDIO_WITH_GCP_STT_URL=https://storyvault-transcribe-audio-with-gcp-speech-to-text-xxxxx-an.a.run.app
STORYVAULT_VIDEO_TEXT_TO_SPEECH_WITH_GOOGLE_URL=https://storyvault-text-to-speech-with-google-xxxxx-an.a.run.app
STORYVAULT_VIDEO_MERGE_VIDEO_AUDIO_NARRATION_URL=https://storyvault-merge-video-audio-narration-xxxxx-an.a.run.app
STORYVAULT_VIDEO_CONCATENATE_SECTION_VIDEOS_URL=https://storyvault-concatenate-section-videos-xxxxx-an.a.run.app
STORYVAULT_VIDEO_ADD_SUBTITLE_URL=https://storyvault-add-video-subtitle-xxxxx-an.a.run.app
STORYVAULT_VIDEO_TRIM_SILENCE_URL=https://storyvault-trim-silence-video-xxxxx-an.a.run.app
STORYVAULT_CLIP_PIPELINE_KICKER_URL=https://storyvault-clip-pipeline-kicker-xxxxx-an.a.run.app
STORYVAULT_CLIP_COMMAND_SERVICE_URL=https://storyvault-clip-command-xxxxx-an.a.run.app

# Guide assistant callable (ask_en_aistudio_guide)
GEMINI_API_KEY=
EN_AISTUDIO_GUIDE_FILE_SEARCH_STORE_NAME=fileSearchStores/xxxxx
GUIDE_MODEL_ID=gemini-2.5-flash-lite

# Datadog LLM Observability
DD_LLMOBS_ENABLED=false
DD_LLMOBS_AGENTLESS_ENABLED=true
DD_LLMOBS_ML_APP=storyvault
DD_SERVICE=storyvault-functions
DD_ENV=dev
DD_SITE=ap1.datadoghq.com
# Prefer Secret Manager / local ignored env for DD_API_KEY.
# DD_API_KEY=

# Google Workspace OAuth (Drive / Sheets)
GOOGLE_WORKSPACE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_WORKSPACE_OAUTH_CLIENT_SECRET=replace-with-oauth-client-secret
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GOOGLE_WORKSPACE_TOKEN_ENCRYPTION_KEY=

# GitHub OAuth (Private repository read)
GITHUB_OAUTH_CLIENT_ID=Ov23lixxxxxxxxxxxxxx
GITHUB_OAUTH_CLIENT_SECRET=replace-with-github-oauth-client-secret
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GITHUB_TOKEN_ENCRYPTION_KEY=

# Slack OAuth (Related conversations)
SLACK_OAUTH_CLIENT_ID=123456789.123456789
SLACK_OAUTH_CLIENT_SECRET=replace-with-slack-oauth-client-secret
# Bot scopes: channels:read,channels:history,groups:read,groups:history
# User scopes: search:read
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SLACK_TOKEN_ENCRYPTION_KEY=

# Atlassian Jira Cloud OAuth 2.0 (3LO)
JIRA_OAUTH_CLIENT_ID=your-atlassian-client-id
JIRA_OAUTH_CLIENT_SECRET=replace-with-atlassian-oauth-client-secret
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
JIRA_TOKEN_ENCRYPTION_KEY=

# ADK artifact GCS finalize → canonical Storage + Firestore
ADK_ARTIFACT_BUCKET=storyvault-dev-adk-artifacts
EN_AISTUDIO_GCS_BUCKET=storyvault-dev.firebasestorage.app
ADK_APP_NAMES=en-aistudio-adk-agent,storyvault-capability-structuring-agent,storyvault-story-generation-agent,slides-generator

# send-mail Cloud Run (backend/microservice/send-mail/deploy.sh)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@your-domain.com
SENDGRID_FROM_NAME=EN AIstudio
