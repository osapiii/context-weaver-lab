# Copy to .env.<project-alias> (gitignored) for Firebase Functions deploy env injection.
# Do not commit real secrets.

# Callable auth email sender (send_admin_sign_in_link)
SEND_MAIL_SERVICE_URL=https://send-mail-xxxxx-an.a.run.app
AI_STUDIO_APP_NAME=VibeControl
AUTH_EMAIL_LINK_ALLOWED_HOSTS=vibe-control-dev.web.app,vibe-control-dev.firebaseapp.com,localhost
EN_AISTUDIO_APP_BASE_URL=https://vibe-control-dev.web.app

# Dev-only auth bypass (custom token sign-in). Keep project allowlist narrow.
DEV_AUTH_BYPASS_PROJECT_IDS=vibe-control-dev
DEV_AUTH_BYPASS_EMAILS=super@enostech.co.jp

# ADK invoke trigger (on_adk_invoke_request_created)
EN_AISTUDIO_ADK_AGENT_URL=https://en-aistudio-adk-agent-q2uwnmd3yq-an.a.run.app
EN_AISTUDIO_ADK_VIBE_CAPABILITY_STRUCTURING_URL=
EN_AISTUDIO_ADK_VIBE_STORY_GENERATION_URL=
ADK_INTERNAL_INVOKE_SECRET=generate-with-openssl-rand-hex-32

# Context Store Cloud Run for FileSpace RequestDocs
CONTEXT_STORE_SERVICE_URL=https://context-store-xxxxx-uc.a.run.app

# Guide assistant callable (ask_en_aistudio_guide)
GEMINI_API_KEY=
EN_AISTUDIO_GUIDE_FILE_SEARCH_STORE_NAME=fileSearchStores/xxxxx
GUIDE_MODEL_ID=gemini-2.5-flash-lite

# Datadog LLM Observability
DD_LLMOBS_ENABLED=false
DD_LLMOBS_AGENTLESS_ENABLED=true
DD_LLMOBS_ML_APP=vibe-control
DD_SERVICE=vibe-control-functions
DD_ENV=dev
DD_SITE=ap1.datadoghq.com
# Prefer Secret Manager / local ignored env for DD_API_KEY.
# DD_API_KEY=

# Google Workspace OAuth (Drive / Sheets)
GOOGLE_WORKSPACE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_WORKSPACE_OAUTH_CLIENT_SECRET=replace-with-oauth-client-secret
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GOOGLE_WORKSPACE_TOKEN_ENCRYPTION_KEY=

# GitHub OAuth (Private repository read)
GITHUB_OAUTH_CLIENT_ID=Ov23lixxxxxxxxxxxxxx
GITHUB_OAUTH_CLIENT_SECRET=replace-with-github-oauth-client-secret
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GITHUB_TOKEN_ENCRYPTION_KEY=

# ADK artifact GCS finalize → canonical Storage + Firestore
ADK_ARTIFACT_BUCKET=vibe-control-dev-adk-artifacts
EN_AISTUDIO_GCS_BUCKET=vibe-control-dev.firebasestorage.app
ADK_APP_NAMES=en-aistudio-adk-agent,vibe-capability-structuring-agent,vibe-story-generation-agent,slides-generator

# send-mail Cloud Run (backend/microservice/send-mail/deploy.sh)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@your-domain.com
SENDGRID_FROM_NAME=EN AIstudio
