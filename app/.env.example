# Copy to .env.local (local:dev), .env.sandbox (dev:generate), or .env.prod (prod:generate).
# Firebase / API keys: see team docs or firebase apps:sdkconfig.

# ローカル開発はデフォルトで実 Firebase（en-aistudio-development 等）に接続します。
# Emulator を使う場合のみ true（または yarn local:dev:emulator）:
# NUXT_PUBLIC_USE_FIREBASE_EMULATOR=true

# Dev-only auth bypass. en-aistudio-development は未設定でも super@enostech.co.jp を許可します。
# NUXT_PUBLIC_DEV_AUTH_BYPASS_ENABLED=true
# NUXT_PUBLIC_DEV_AUTH_BYPASS_EMAILS=super@enostech.co.jp

# Firebase Web SDK config (development: en-aistudio-development)
NUXT_PUBLIC_FIREBASECONFIG_APIKEY=AIzaSyAt-7USeNbEdoUdwzI2vf7GGKBpfI0EeBo
NUXT_PUBLIC_FIREBASECONFIG_AUTHDOMEIN=en-aistudio-development.firebaseapp.com
NUXT_PUBLIC_FIREBASECONFIG_PROJECTID=en-aistudio-development
NUXT_PUBLIC_FIREBASECONFIG_STORAGEBUCKET=en-aistudio-development.firebasestorage.app
NUXT_PUBLIC_FIREBASECONFIG_APPID=1:509107319597:web:9d9c026f2a2065b68a19a4

# 取引先プロファイル自動取得 (法人番号 / 公式URL). GBIZ トークンは Cloud Run 側のみ。
# NUXT_PUBLIC_CORPORATE_INFO_LOOKUP_ENDPOINT=https://corporate-info-lookup-xxxxx-an.a.run.app/lookup

# AI Studio / EN AI Studio Assistant: ADK invoke（デフォルト ON。legacy 直叩きは false で無効化）
# NUXT_PUBLIC_ADK_INVOKE_VIA_REQUEST_DOC=false
# NUXT_PUBLIC_EN_AISTUDIO_ADK_BASE_URL=https://en-aistudio-adk-agent-xxxxx-an.a.run.app

# Google Workspace OAuth (Drive / Sheets)
# Google Cloud Console の OAuth Web client ID。client secret は backend 側にのみ設定。
# NUXT_PUBLIC_GOOGLE_WORKSPACE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Datadog RUM / Browser Logs / Session Replay
# NUXT_PUBLIC_DATADOG_APPLICATIONID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# NUXT_PUBLIC_DATADOG_CLIENTTOKEN=pubxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NUXT_PUBLIC_DATADOG_SITE=ap1.datadoghq.com
# NUXT_PUBLIC_DATADOG_SERVICE=en-aistudio-frontend
# NUXT_PUBLIC_DATADOG_ENV=dev
# NUXT_PUBLIC_APP_VERSION=0.0.0-local

# 管理者ログインメールは Firebase Callable Function
# send_admin_sign_in_link -> send-mail Cloud Run で送信します。
# Functions 側の SEND_MAIL_SERVICE_URL / SENDGRID_* は ../backend/app/.env.example を参照。
