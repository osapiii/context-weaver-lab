# Copy to .env.local (local:dev), .env.storyvault-dev (dev:generate), or .env.prod (prod:generate).
# Firebase / API keys: see team docs or firebase apps:sdkconfig.

# ローカル開発はデフォルトで実 Firebase（storyvault-dev）に接続します。
# Emulator を使う場合のみ true（または yarn local:dev:emulator）:
# NUXT_PUBLIC_USE_FIREBASE_EMULATOR=true

# Dev-only auth bypass. storyvault-dev は未設定でも super@enostech.co.jp を許可します。
# NUXT_PUBLIC_DEV_AUTH_BYPASS_ENABLED=true
# NUXT_PUBLIC_DEV_AUTH_BYPASS_EMAILS=super@enostech.co.jp

# Firebase Web SDK config (development: storyvault-dev)
NUXT_PUBLIC_FIREBASECONFIG_APIKEY=AIzaSyDYLti7uOodhnRwoJzlFvvzAvgy0s9XBbk
NUXT_PUBLIC_FIREBASECONFIG_AUTHDOMEIN=storyvault-dev.firebaseapp.com
NUXT_PUBLIC_FIREBASECONFIG_PROJECTID=storyvault-dev
NUXT_PUBLIC_FIREBASECONFIG_STORAGEBUCKET=storyvault-dev.firebasestorage.app
NUXT_PUBLIC_FIREBASECONFIG_APPID=1:539230065284:web:27ce9517eeeea78c8ca8d1
# Firebase App Check (Web / reCAPTCHA Enterprise public site key)
# NUXT_PUBLIC_FIREBASE_APPCHECK_RECAPTCHA_ENTERPRISE_SITE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 取引先プロファイル自動取得 (法人番号 / 公式URL). GBIZ トークンは Cloud Run 側のみ。
# NUXT_PUBLIC_CORPORATE_INFO_LOOKUP_ENDPOINT=https://corporate-info-lookup-xxxxx-an.a.run.app/lookup

# AI Studio / EN AI Studio Assistant: ADK invoke（デフォルト ON。legacy 直叩きは false で無効化）
# NUXT_PUBLIC_ADK_INVOKE_VIA_REQUEST_DOC=false
NUXT_PUBLIC_EN_AISTUDIO_ADK_BASE_URL=https://en-aistudio-adk-agent-mdgjayj74q-an.a.run.app
NUXT_PUBLIC_ADK_ARTIFACT_BUCKET=storyvault-dev-adk-artifacts

# Google Workspace OAuth (Drive / Sheets)
# Google Cloud Console の OAuth Web client ID。client secret は backend 側にのみ設定。
# NUXT_PUBLIC_GOOGLE_WORKSPACE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com

# GitHub OAuth (Private repository read)
# GitHub OAuth App の Client ID。client secret と token は backend 側にのみ設定。
NUXT_PUBLIC_GITHUB_OAUTH_CLIENT_ID=Ov23lixxxxxxxxxxxxxx
# 省略時は GitHub OAuth App に登録されている callback URL を使用します。
NUXT_PUBLIC_GITHUB_OAUTH_REDIRECT_URI=https://storyvault-dev.web.app/admin/storyvault/github-callback

# Slack OAuth (Related conversations)
# Slack App の Client ID。client secret と token は backend 側にのみ設定。
# NUXT_PUBLIC_SLACK_OAUTH_CLIENT_ID=123456789.123456789
# 省略時は Slack App に登録されている callback URL を使用します。
# NUXT_PUBLIC_SLACK_OAUTH_REDIRECT_URI=https://storyvault-dev.web.app/admin/storyvault/slack-callback

# Atlassian Jira Cloud OAuth 2.0 (3LO)
# Atlassian developer console の Client ID。Client secret は backend 側にのみ設定。
# NUXT_PUBLIC_JIRA_OAUTH_CLIENT_ID=your-atlassian-client-id
# 省略時は現在のhostから callback URLを組み立てます。
# NUXT_PUBLIC_JIRA_OAUTH_REDIRECT_URI=https://storyvault-dev.web.app/admin/storyvault/jira-callback

# StoryVault Remote MCP
NUXT_PUBLIC_STORYVAULT_MCP_URL=https://storyvault-mcp-mdgjayj74q-an.a.run.app/mcp
# Optional: override the Skill install command shown on the StoryVault setup screen.
# NUXT_PUBLIC_STORYVAULT_SKILL_INSTALL_COMMAND="mkdir -p ~/.codex/skills/storyvault-codex-skill && curl -fsSL https://storyvault-dev.web.app/installers/storyvault-codex-skill/SKILL.md -o ~/.codex/skills/storyvault-codex-skill/SKILL.md"

# Datadog RUM / Browser Logs / Session Replay
# NUXT_PUBLIC_DATADOG_APPLICATIONID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# NUXT_PUBLIC_DATADOG_CLIENTTOKEN=pubxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NUXT_PUBLIC_DATADOG_SITE=ap1.datadoghq.com
# NUXT_PUBLIC_DATADOG_SERVICE=storyvault-frontend
# NUXT_PUBLIC_DATADOG_ENV=dev
# NUXT_PUBLIC_APP_VERSION=0.0.0-local

# 管理者ログインメールは Firebase Callable Function
# send_admin_sign_in_link -> send-mail Cloud Run で送信します。
# Functions 側の SEND_MAIL_SERVICE_URL / SENDGRID_* は ../backend/app/.env.example を参照。
